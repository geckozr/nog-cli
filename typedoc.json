{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/**/*.ts"],
  "out": "dist-docs",
  "name": "Nog CLI Developer Guide",
  "includeVersion": true,
  "readme": "docs/DOCUMENTATION.md",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "excludeInternal": true,
  "exclude": [
    "src/main.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/index.ts",
    "test-output/**",
    "test-output-baseline/**",
    "dist/**"
  ],
  "gitRevision": "main",
  "disableSources": false
}
